---
import { Icon } from 'astro-icon/components';
interface Props { label: string; }
const { label } = Astro.props;
---
<button id="theme-toggle" class="t" aria-label={label} title={label}>
  <Icon name="lucide:sun" class="i-sun" />
  <Icon name="lucide:moon" class="i-moon" />
</button>

<style>
  .t {
    display: inline-flex;
    width: 2.1rem;
    height: 2.1rem;
    align-items: center;
    justify-content: center;
    border-radius: 8px;
    color: var(--fg-muted);
  }
  .t:hover { color: var(--accent); background: var(--bg-elevated); }
  .t :global(svg) { width: 1.05rem; height: 1.05rem; }
  :root[data-theme='light'] .i-moon { display: none; }
  :root:not([data-theme='light']) .i-sun { display: none; }
</style>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'light' ? 'dark' : 'light';
    if (next === 'dark') root.removeAttribute('data-theme');
    else root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });
</script>
